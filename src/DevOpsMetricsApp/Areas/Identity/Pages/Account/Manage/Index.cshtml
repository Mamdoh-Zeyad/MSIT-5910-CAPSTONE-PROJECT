@page
@model IndexModel
@{
    ViewData["Title"] = "My Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center animate__animated animate__fadeInUp mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-block p-4 mb-3">
                        <i class="fa-solid fa-user-astronaut fa-3x"></i>
                    </div>
                    <h3 class="fw-bold">Account Settings</h3>
                    <p class="text-muted">Manage your personal information and security.</p>
                </div>

                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control bg-light rounded-3" disabled />
                        <label asp-for="Username"><i class="fa-solid fa-user me-2 text-muted"></i>Username</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.PhoneNumber" class="form-control rounded-3" />
                        <label asp-for="Input.PhoneNumber"><i class="fa-solid fa-phone me-2 text-muted"></i>Phone Number (Optional)</label>
                        <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                    </div>

                    <button id="update-profile-button" type="submit" class="w-100 btn btn-lg btn-primary rounded-pill shadow-sm mb-3">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Save Changes
                    </button>

                    <hr class="my-4" />

                    <div class="text-center">
                        <p class="text-muted mb-2">Need to update your security credentials?</p>
                        <a asp-page="./ChangePassword" class="btn btn-outline-secondary rounded-pill w-100">
                            <i class="fa-solid fa-key me-2"></i>Change Password
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}