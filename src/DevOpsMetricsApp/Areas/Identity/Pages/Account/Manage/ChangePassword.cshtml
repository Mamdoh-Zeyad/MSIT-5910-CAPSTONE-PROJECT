@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center animate__animated animate__fadeInUp mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold m-0"><i class="fa-solid fa-shield-halved text-primary me-2"></i>Security Settings</h3>
                    <a asp-page="./Index" class="btn btn-outline-secondary btn-sm rounded-pill"><i class="fa-solid fa-arrow-left me-1"></i>Back to Profile</a>
                </div>
                <p class="text-muted mb-4">Ensure your account is using a strong, random password to stay secure.</p>
                <hr class="mb-4" />

                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.OldPassword" class="form-control rounded-3" autocomplete="current-password" aria-required="true" placeholder="Old Password" />
                        <label asp-for="Input.OldPassword"><i class="fa-solid fa-lock text-muted me-2"></i>Current Password</label>
                        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.NewPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="New Password" />
                        <label asp-for="Input.NewPassword"><i class="fa-solid fa-key text-muted me-2"></i>New Password</label>
                        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Input.ConfirmPassword" class="form-control rounded-3" autocomplete="new-password" aria-required="true" placeholder="Confirm Password" />
                        <label asp-for="Input.ConfirmPassword"><i class="fa-solid fa-check-double text-muted me-2"></i>Confirm New Password</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="w-100 btn btn-lg btn-primary rounded-pill shadow-sm">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Update Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}