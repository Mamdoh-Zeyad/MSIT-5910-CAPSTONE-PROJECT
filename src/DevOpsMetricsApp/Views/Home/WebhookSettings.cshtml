@{
    ViewData["Title"] = "Webhook Configuration";
}

<div class="row justify-content-center mt-4 animate__animated animate__fadeInDown">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-5">
                <h3 class="fw-bold mb-4"><i class="fa-solid fa-plug text-primary me-2"></i>CI/CD Webhook Integration</h3>
                <p class="text-muted">Use the credentials below to configure Jenkins, GitHub Actions, or GitLab to push deployment telemetry to this dashboard.</p>

                <hr class="mb-4" />

                <div class="mb-4">
                    <label class="fw-bold text-dark mb-2">Endpoint URL (POST)</label>
                    <div class="input-group">
                        <input type="text" class="form-control font-monospace bg-light" value="@ViewBag.WebhookUrl" id="webhookUrl" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('webhookUrl').value); alert('URL copied to clipboard!');">
                            <i class="fa-solid fa-copy"></i>
                        </button>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="fw-bold text-dark mb-2">Enterprise API Secret (Header: X-API-Key)</label>
                    <div class="input-group">
                        <input type="password" class="form-control font-monospace bg-light" value="@ViewBag.SecretKey" id="secretKey" readonly>
                        <button class="btn btn-outline-secondary" type="button" onclick="var el = document.getElementById('secretKey'); el.type = el.type === 'password' ? 'text' : 'password';">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="alert alert-info rounded-3 mt-4 border-0">
                    <strong><i class="fa-solid fa-circle-info me-2"></i>Payload Format:</strong>
                    Ensure your pipeline sends the payload as <code>application/json</code> matching the required <code>DeploymentRecord</code> schema.
                </div>

                <div class="mt-4 text-end">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="fa-solid fa-arrow-left me-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>