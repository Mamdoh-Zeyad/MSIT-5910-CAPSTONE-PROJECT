@{
    ViewData["Title"] = "Operations Dashboard";
}

<div class="row mb-5 animate__animated animate__fadeInDown">
    <div class="col-md-8">
        <h2 class="fw-bold text-dark">Welcome back, Technical Lead</h2>
        <p class="text-muted">Here is the real-time telemetry and ML.NET risk assessment for your CI/CD pipelines.</p>
    </div>
    <div class="col-md-4 text-md-end align-self-center">
        <button class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="fa-solid fa-download me-2"></i>Export Report</button>
    </div>
</div>

<div class="row mb-5">
    <div class="col-md-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
        <div class="card metric-card shadow-sm h-100 bg-white">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Deployment Frequency</h6>
                    <h3 class="fw-bold mb-0 text-dark">24 <span class="fs-6 text-success"><i class="fa-solid fa-arrow-up"></i> 12%</span></h3>
                    <small class="text-muted">Deploys this week</small>
                </div>
                <div class="metric-icon text-primary bg-primary bg-opacity-10 p-3 rounded-circle">
                    <i class="fa-solid fa-rocket"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
        <div class="card metric-card shadow-sm h-100 bg-white border-bottom border-warning border-4">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Change Failure Rate</h6>
                    <h3 class="fw-bold mb-0 text-dark">12% <span class="fs-6 text-warning"><i class="fa-solid fa-minus"></i> 0%</span></h3>
                    <small class="text-muted">Requires attention</small>
                </div>
                <div class="metric-icon text-warning bg-warning bg-opacity-10 p-3 rounded-circle">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
        <div class="card metric-card shadow-sm h-100 bg-white">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Avg Build Duration</h6>
                    <h3 class="fw-bold mb-0 text-dark">4m 12s</h3>
                    <small class="text-success"><i class="fa-solid fa-check-circle me-1"></i>Stable across repos</small>
                </div>
                <div class="metric-icon text-info bg-info bg-opacity-10 p-3 rounded-circle">
                    <i class="fa-solid fa-stopwatch"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row animate__animated animate__fadeInUp" style="animation-delay: 0.4s;">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold m-0"><i class="fa-solid fa-microchip text-danger me-2"></i>High-Risk Deployments (ML.NET)</h4>
            <a href="#" class="text-decoration-none">View All Logs</a>
        </div>

        <div class="table-responsive table-modern">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Repository</th>
                        <th>Commit Hash</th>
                        <th>Author ID (Anonymized)</th>
                        <th>Failure Probability</th>
                        <th>Action Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-4 fw-semibold"><i class="fa-brands fa-github me-2 text-secondary"></i>Aquat-Billing-API</td>
                        <td><span class="badge bg-light text-dark border font-monospace">a1b2c3d</span></td>
                        <td><i class="fa-solid fa-user-shield me-2 text-muted"></i>USR-8842</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="text-danger fw-bold me-2">87%</span>
                                <div class="progress flex-grow-1" style="height: 6px;">
                                    <div class="progress-bar bg-danger" role="progressbar" style="width: 87%;"></div>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge rounded-pill bg-danger"><i class="fa-solid fa-ban me-1"></i>Intercepted</span></td>
                    </tr>
                    <tr>
                        <td class="ps-4 fw-semibold"><i class="fa-brands fa-gitlab me-2 text-warning"></i>Inventory-Web-Portal</td>
                        <td><span class="badge bg-light text-dark border font-monospace">f9e8d7c</span></td>
                        <td><i class="fa-solid fa-user-shield me-2 text-muted"></i>USR-2219</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <span class="text-warning fw-bold me-2">45%</span>
                                <div class="progress flex-grow-1" style="height: 6px;">
                                    <div class="progress-bar bg-warning" role="progressbar" style="width: 45%;"></div>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge rounded-pill bg-warning text-dark"><i class="fa-solid fa-eye me-1"></i>Review Required</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>