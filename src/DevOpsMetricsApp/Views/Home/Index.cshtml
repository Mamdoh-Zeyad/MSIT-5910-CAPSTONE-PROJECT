@model DevOpsMetricsApp.Models.DashboardViewModel
@{
    ViewData["Title"] = "Operations Dashboard";
}

<div class="row mb-5 animate__animated animate__fadeInDown">
    <div class="col-md-6">
        <h2 class="fw-bold text-dark">Welcome back, Technical Lead</h2>
        <p class="text-muted">Here is the real-time telemetry and ML.NET risk assessment for your CI/CD pipelines.</p>
    </div>
    <div class="col-md-6 text-md-end align-self-center">
        <!-- Generate Data Form -->
        <form asp-action="GenerateMockData" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-warning rounded-pill px-4 shadow-sm me-2">
                <i class="fa-solid fa-database me-2"></i>Generate Mock Data
            </button>
        </form>
        <!-- Real CSV Export Link -->
        <a asp-action="ExportTelemetryCsv" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-download me-2"></i>Export Report
        </a>
    </div>
</div>

<div class="row mb-5">
    <div class="col-md-3 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
        <div class="card metric-card shadow-sm h-100 bg-white">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Total Deploys</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.TotalDeployments</h3>
                </div>
                <div class="metric-icon text-primary bg-primary bg-opacity-10 p-3 rounded-circle">
                    <i class="fa-solid fa-rocket"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
        <!-- Dynamically changes border color if failure rate is > 10% -->
        <div class="card metric-card shadow-sm h-100 bg-white @(Model.FailureRate > 10 ? "border-bottom border-warning border-4" : "")">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Failure Rate</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.FailureRate.ToString("0.0")%</h3>
                </div>
                <div class="metric-icon text-warning bg-warning bg-opacity-10 p-3 rounded-circle">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
        <div class="card metric-card shadow-sm h-100 bg-white">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Avg Duration</h6>
                    <h3 class="fw-bold mb-0 text-dark">@Model.AverageBuildTime.ToString("0.0")s</h3>
                </div>
                <div class="metric-icon text-info bg-info bg-opacity-10 p-3 rounded-circle">
                    <i class="fa-solid fa-stopwatch"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- NEW ML.NET CARD -->
    <div class="col-md-3 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.4s;">
        <div class="card metric-card shadow-sm h-100 bg-primary text-white border-0">
            <div class="card-body p-4 d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-white-50 text-uppercase fw-bold mb-2">AI Predicted Next</h6>
                    <h3 class="fw-bold mb-0 text-white">@Model.PredictedNextBuildTime.ToString("0.0")s</h3>
                </div>
                <div class="metric-icon text-white bg-white bg-opacity-25 p-3 rounded-circle">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row animate__animated animate__fadeInUp" style="animation-delay: 0.5s;">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="fw-bold m-0"><i class="fa-solid fa-list-check text-dark me-2"></i>Recent Pipeline Executions</h4>
        </div>

        <div class="table-responsive table-modern shadow-sm rounded-4 overflow-hidden">
            <table class="table table-hover mb-0 bg-white">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Repository</th>
                        <th>Commit Hash</th>
                        <th>Author ID</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentDeployments.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                <i class="fa-solid fa-inbox fa-2x mb-2"></i><br />
                                No telemetry data available. Click "Generate Mock Data" to populate the dashboard.
                            </td>
                        </tr>
                    }
                    @foreach (var record in Model.RecentDeployments)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold"><i class="fa-brands fa-git-alt me-2 text-secondary"></i>@record.RepositoryName</td>
                            <td><span class="badge bg-light text-dark border font-monospace">@record.CommitHash</span></td>
                            <td><i class="fa-solid fa-user-shield me-2 text-muted"></i>@record.AnonymizedAuthorId</td>
                            <td>@record.BuildDurationSeconds.ToString("0.0")s</td>
                            <td>
                                @if (record.IsSuccessful)
                                {
                                    <span class="badge rounded-pill bg-success"><i class="fa-solid fa-check me-1"></i>Passed</span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-danger"><i class="fa-solid fa-ban me-1"></i>Failed</span>
                                }
                            </td>
                            <td><small class="text-muted">@record.Timestamp.ToLocalTime().ToString("g")</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>